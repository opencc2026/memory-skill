{
  "name": "memory-skill",
  "version": "0.1.0",
  "description": "多Agent实时记忆系统，支持对象存储",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "npm run lint && npm test",
    "docs": "jsdoc -c jsdoc.json",
    "docker:build": "docker build -t memory-skill .",
    "docker:run": "docker run -p 3000:3000 memory-skill"
  },
  "keywords": [
    "memory",
    "storage",
    "s3",
    "multi-agent",
    "real-time",
    "clawhub",
    "skill"
  ],
  "author": "opencc2026 <opencc2026@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opencc2026/memory-skill.git"
  },
  "bugs": {
    "url": "https://github.com/opencc2026/memory-skill/issues"
  },
  "homepage": "https://github.com/opencc2026/memory-skill#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/lib-storage": "^3.540.0",
    "minio": "^8.0.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "crypto-js": "^4.1.1",
    "zlib": "^1.0.5",
    "fs-extra": "^11.2.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "ajv": "^8.12.0",
    "fast-json-patch": "^3.1.1",
    "lunr": "^2.3.9",
    "node-cache": "^5.1.2",
    "p-queue": "^7.3.4",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "nodemon": "^3.0.1",
    "jsdoc": "^4.0.2",
    "supertest": "^6.3.3",
    "mock-aws-s3": "^4.0.2",
    "redis-mock": "^0.56.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.10",
    "typescript": "^5.2.2"
  },
  "files": [
    "src/",
    "README.md",
    "SKILL.md",
    "package.json",
    "LICENSE",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "clawhub": {
    "category": "storage",
    "tags": ["memory", "multi-agent", "s3", "real-time"],
    "compatibility": {
      "openclaw": ">=1.0.0"
    }
  }
}