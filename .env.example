# Memory Skill 环境配置
# 复制此文件为 .env 并填写实际值

# ==================== 存储配置 ====================
# 存储类型: s3, local, memory
STORAGE_TYPE=s3

# S3配置
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-access-key-here
S3_SECRET_KEY=your-secret-key-here
S3_BUCKET=memory-storage
S3_REGION=us-east-1
S3_PATH_STYLE=false
S3_SSL_ENABLED=true

# 本地存储配置
LOCAL_STORAGE_PATH=./memory-data
LOCAL_MAX_FILE_SIZE=10485760  # 10MB

# 内存存储配置
MEMORY_STORAGE_MAX_SIZE=10000

# ==================== 记忆配置 ====================
# 记忆生存时间（毫秒），0表示永不过期
MEMORY_TTL=86400000  # 24小时

# 加密配置
MEMORY_ENCRYPTION_ENABLED=false
MEMORY_ENCRYPTION_KEY=your-encryption-key-here  # 32字节密钥

# 压缩配置
MEMORY_COMPRESSION_ENABLED=true

# 索引配置
MEMORY_INDEXING_ENABLED=true
MEMORY_MAX_ENTRIES=1000  # 每个Agent最大记忆数

# ==================== Agent配置 ====================
AGENTS_MAX_AGENTS=100
AGENTS_DEFAULT_PERMISSIONS=read,write

# 协作配置
AGENTS_COLLABORATION_ENABLED=true
AGENTS_COLLABORATION_REQUIRE_APPROVAL=false
AGENTS_COLLABORATION_MAX_COLLABORATORS=10

# 共享记忆配置
AGENTS_SHARED_MEMORY_ENABLED=true
AGENTS_SHARED_MEMORY_VISIBILITY=restricted  # public, restricted, private

# ==================== 性能配置 ====================
# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300000  # 5分钟
CACHE_MAX_SIZE=1000

# 批量操作配置
BATCH_ENABLED=true
BATCH_SIZE=100
BATCH_INTERVAL=1000  # 1秒

# ==================== 监控配置 ====================
# 日志配置
LOGGING_LEVEL=info  # error, warn, info, debug
LOGGING_FORMAT=json

# 指标配置
METRICS_ENABLED=true
METRICS_INTERVAL=60000  # 1分钟

# ==================== 安全配置 ====================
# API密钥（可选）
API_KEY_ENABLED=false
API_KEY=your-api-key-here

# CORS配置
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ==================== 服务配置 ====================
# HTTP服务配置
HTTP_PORT=3000
HTTP_HOST=0.0.0.0

# WebSocket配置（实时更新）
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001

# ==================== 备份配置 ====================
# 自动备份
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600000  # 1小时
BACKUP_RETENTION_DAYS=7

# ==================== 开发配置 ====================
# 调试模式
DEBUG_ENABLED=false
DEBUG_LEVEL=verbose

# 测试配置
TEST_STORAGE_TYPE=memory  # 测试时使用内存存储
TEST_CLEANUP=true